server {
    listen 80;
    server_name 165.99.199.24;

    location /attendance {
        root /home/izzul/webapps;
        index index.php index.html;
        try_files $uri $uri/ /attendance/index.php?$query_string;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/var/run/php/php8.2-fpm.sock; # adjust PHP version if needed
    }

    location ~ /\.ht {
        deny all;
    }
}
